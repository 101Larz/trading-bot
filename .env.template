# =============================================================================
# Trading Bot — Environment Variable Template
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to git.
# =============================================================================

# --- Alpaca Markets -----------------------------------------------------------
# Paper trading (safe default — switch URL for live)
APCA_API_KEY_ID=your_alpaca_paper_key_id
APCA_API_SECRET_KEY=your_alpaca_paper_secret_key
APCA_BASE_URL=https://paper-api.alpaca.markets

# Set to "false" ONLY when you are ready for live trading
PAPER_MODE=true

# --- Anthropic ----------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- Notifications ------------------------------------------------------------
# SendGrid (for daily email digests)
SENDGRID_API_KEY=your_sendgrid_api_key
NOTIFY_FROM_EMAIL=agent@yourdomain.com
NOTIFY_TO_EMAIL=you@yourdomain.com

# Slack webhook (optional — leave blank to disable)
SLACK_WEBHOOK_URL=

# Discord webhook (optional — leave blank to disable)
DISCORD_WEBHOOK_URL=

# --- Bot Settings -------------------------------------------------------------
# Maximum portfolio allocation per position (fraction, e.g. 0.05 = 5%)
MAX_POSITION_PCT=0.05

# Minimum cash reserve (fraction, e.g. 0.20 = 20%)
CASH_RESERVE_PCT=0.20

# Stop-loss threshold per position (fraction, e.g. 0.08 = 8%)
STOP_LOSS_PCT=0.08

# Daily loss limit before all trading halts (fraction, e.g. 0.03 = 3%)
DAILY_LOSS_LIMIT_PCT=0.03

# Maximum concurrent open positions
MAX_POSITIONS=10

# Timezone for scheduling
TIMEZONE=America/New_York
